{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/frame.js": {
      "includeFiles": "dist/index.html",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/frame", "methods": ["GET", "POST", "OPTIONS"], "dest": "/api/frame" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/", "methods": ["GET", "POST", "OPTIONS"], "dest": "/api/frame" },
    { "src": "/index.html", "methods": ["GET", "POST", "OPTIONS"], "dest": "/api/frame" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://crm.artflowers.kz https://*.bitrix24.ru https://*.bitrix24.com https://*.bitrix24.kz 'self'"
        }
      ]
    }
  ]
}
